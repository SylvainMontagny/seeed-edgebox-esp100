    {
        "id": "298077ef917bc4e4",
        "type": "function",
        "z": "8b7d06cf1eb39e35",
        "name": "ephemeride/weekly (3)",
        "func": "    let step = flow.get('step');\n    let client = new bacnet.default({\n        apduTimeout: 2000,\n        broadcastAddress: flow.get('ipBroadcast'),\n        port: flow.get('port'),\n        maxSegments: bacnet.MaxSegmentsAccepted.SEGMENTS_65\n    });\n\n\n            switch (msg.payload)   \n            {\n\n                \n                default:\n                    try \n                    {\n                    const address = { address:flow.get('ip')+\":\"+flow.get('port')};\n                    const value = await client.readProperty(\n                        address,\n                        { type: bacnet.ObjectType.SCHEDULE, instance: 0},\n                        bacnet.PropertyIdentifier.WEEKLY_SCHEDULE\n                    );\n\n                    const weekly = (value.values[0]?.value) || [];\n                    \n                        const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];\n                    \n                  \n\n                 \n\n                    let starttime = new Array;\n                    let endtime = new Array;\n                    \n                    for(let i = 0;i<7; i++)\n                    {\n                        let temp =  weekly[i];\n                     \n                        starttime[i] = bacnettimeConverter(temp[0].time.value);\n                        endtime[i] =   bacnettimeConverter(temp[1].time.value);\n                    }\n\n                    msg.payload = 'Are the night start/end times correct? \\n Press OK/NOT OK. \\n' + \n                    '\\n Monday :' + starttime[0] +' to ' + endtime[0] + \n                    '\\n Tuesday :' + starttime[1] + ' to ' + endtime[1] + \n                    '\\n Wednesday :' + starttime[2] + ' to ' + endtime[2] + \n                    '\\n Thursday :' + starttime[3] + ' to ' + endtime[3] + \n                    '\\n Friday :' + starttime[4] + ' to ' + endtime[4] + \n                    '\\n Saturday :' + starttime[5] + ' to ' + endtime[5] + \n                    '\\n Sunday :' + starttime[6] + ' to ' + endtime[6] \n                    node.send([null, msg]);\n                } catch (err) {\n                    node.error('Erreur: ' + JSON.stringify(err, Object.getOwnPropertyNames(err)));\n                }\n                \n    \n            break;\n        case (\"OK\"):\n\n            let temp = flow.get(\"tests\");\n            temp.ephemeride = true;\n            temp.weekly_schedule = true;\n            msg.payload = \"START\";\n            flow.set(\"tests\", temp);\n            step++;\n            flow.set('step',step);\n            return [msg, null];\n            break;\n        case (\"NOK\"):\n            step++;\n            flow.set('step',step);\n             msg.payload = \"START\";\n            return [msg, null];\n            break;\n        case (\"SKIP\"):\n            step++;\n            flow.set('step',step);\n            msg.payload = \"START\";\n            return [msg, null];\n            break;\n    }\n\n\n\n  function bacnettimeConverter(bacnetTime) {\n        let time = \"\";\n        for (let i = 16; i < 24; i++) {\n\n            time += bacnetTime.toString()[i];\n\n        }\n        var bacnetFullTime =  time;\n        return bacnetFullTime;\n    }",
