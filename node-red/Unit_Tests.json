    {
        "id": "63e328cf752afec8",
        "type": "function",
        "z": "8b7d06cf1eb39e35",
        "name": "special events",
        "func": "    let step = flow.get('step');\n    let client = new bacnet.default({\n        apduTimeout: 2000,\n        broadcastAddress: flow.get('ipBroadcast'),\n        port: flow.get('port'),\n        maxSegments: bacnet.MaxSegmentsAccepted.SEGMENTS_65\n    });\n\n\n        switch (msg.payload)   \n        {\n\n                \n        default:\n        try {\n\n        const address = { address:flow.get('ip')+\":\"+flow.get('port')};\n        const value = await client.readProperty(\n            address,\n            { type: bacnet.ObjectType.SCHEDULE, instance: 5001 },\n            bacnet.PropertyIdentifier.EXCEPTION_SCHEDULE\n        );\n\n        node.warn('RAW VALUE: ' + JSON.stringify(value, null, 2));\n\n        const exceptions = (value.values[0]?.value) || [];\n\n        const result = exceptions.map((specialEvent, index) => {\n            // Inspecter chaque événement brut\n\n            // La structure peut être à un niveau différent selon le device/lib\n            const raw = specialEvent?.value ?? specialEvent;\n            const period = raw?.period ?? raw?.calendarEntry ?? raw;\n            const timeValues = (raw?.listOfTimeValues || raw?.timeValues || []).map(tv => ({\n                time: tv?.time,\n                value: tv?.value\n            }));\n        });\n\n    } catch (err) {\n        node.error('Erreur: ' + JSON.stringify(err, Object.getOwnPropertyNames(err)));\n    }    \n        break;\n\n        case (\"OK\"):\n\n            let temp = flow.get(\"tests\");\n            temp.special_events = true;\n            flow.set(\"tests\", temp);\n            step++;\n            flow.set('step',step);\n            return [msg, null];\n        break;\n        case (\"NOK\"):\n            step++;\n            flow.set('step',step);\n            return [msg, null];\n        break;\n        case (\"SKIP\"):\n            step++;\n            flow.set('step',step);\n            return [msg, null];\n        break;\n    }\n\n\n\n  function bacnettimeConverter(bacnetTime) {\n        let time = \"\";\n        for (let i = 16; i < 24; i++) {\n\n            time += bacnetTime.toString()[i];\n\n        }\n        var bacnetFullTime =  time;\n        return bacnetFullTime;\n    }",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
