    {
        "id": "f26b2cdf2897e850",
        "type": "function",
        "z": "8b7d06cf1eb39e35",
        "name": "NTP sync (1)",
        "func": "    let step = flow.get('step');\n    let client = new bacnet.default({\n        apduTimeout: 2000,\n        broadcastAddress: flow.get('ipBroadcast'),\n        port: flow.get('port'),\n        maxSegments: bacnet.MaxSegmentsAccepted.SEGMENTS_65\n    });\n\n    switch (msg.payload) {\n\n\n        case (\"START\"):\n\n            msg.payload = \"Eteindre le device testé, attendre un moment arbitraire, le rallumer. Une fois rallumé, cliquer sur le bouton 'Done'\";\n            node.send([null, msg]);\n            break;\n        case (\"DONE\"):\n            let datevalue = await client.readProperty({\n                address: flow.get('ip')\n            }, {\n                instance: flow.get('deviceInstance'),\n                type: 8\n            }, bacnet.PropertyIdentifier.LOCAL_DATE);\n\n            let timevalue = await client.readProperty({\n                address: flow.get('ip')\n            }, {\n                instance: flow.get('deviceInstance'),\n                type: 8\n            }, bacnet.PropertyIdentifier.LOCAL_TIME);\n\n            let parsedTime = timeConverter(flow.get('time'));\n            let bacnetFullTime = bacnettimeConverter(datevalue.values[0].value, timevalue.values[0].value);\n            msg.payload = 'Is the device current time conform ? \\n Press OK/NOT OK. \\n device time : ' + bacnetFullTime + ' \\n UTC time : ' + parsedTime;\n            node.send([null, msg]);\n            break;\n        case (\"OK\"):\n            let temp = flow.get(\"tests\");\n            temp.ntp_sync = true;\n            flow.set(\"tests\", temp);\n            msg.payload = \"ntp sync OK\";\n            node.send([null, msg]);\n            msg.payload = \"START\";\n            step++;\n            node.warn(\"going to step\" +  step);\n            flow.set('step',step);\n            return [msg, null];\n            break;\n        case (\"NOK\"):\n            msg.payload = \"ntp sync not OK\";\n            node.send([null, msg]);\n            msg.payload = \"START\";\n            step++;\n            node.warn(\"going to step\" +  step);\n            flow.set('step',step);\n            return [msg, null];\n            break;\n        case (\"SKIP\"):\n            msg.payload = \"Skipped\";\n            node.send([null, msg]);\n            msg.payload = \"START\";\n            step++;\n            node.warn(\"going to step\" +  step);\n            flow.set('step',step);\n            return [msg, null];\n            break;\n\n    }\n\n    function timeConverter(UNIX_timestamp) {\n        var a = new Date(UNIX_timestamp * 1000);\n        var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n        var year = a.getFullYear();\n        var month = months[a.getMonth()];\n        var date = a.getDate();\n        var hour = a.getHours();\n        var min = a.getMinutes();\n        var sec = a.getSeconds();\n        var time = month + ' ' + date + ' ' + year + ' ' + hour + ':' + min + ':' + sec;\n        return time;\n    }\n\n    function bacnettimeConverter(bacnetDate, bacnetTime) {\n        let date = \"\";\n        let time = \"\";\n        for (let i = 4; i < 15; i++) {\n            date += bacnetDate.toString()[i];\n        }\n        for (let i = 16; i < 24; i++) {\n\n            time += bacnetTime.toString()[i];\n\n        }\n        var bacnetFullTime = date + ' ' + time;\n        return bacnetFullTime;\n    }\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
            {
                "var": "bacnet",
                "module": "@bacnet-js/client"
            }
        ],
        "x": 560,
        "y": 220,
        "wires": [
