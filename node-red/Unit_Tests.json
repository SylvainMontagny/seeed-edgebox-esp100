    {
        "id": "298077ef917bc4e4",
        "type": "function",
        "z": "8b7d06cf1eb39e35",
        "name": "ephemeride (2)",
        "func": "let step = flow.get('step');\n    let client = new bacnet.default({\n        apduTimeout: 2000,\n        broadcastAddress: flow.get('ipBroadcast'),\n        port: flow.get('port'),\n        maxSegments: bacnet.MaxSegmentsAccepted.SEGMENTS_65\n    });\n\n\n    switch (msg.payload)   \n    {\n        default:\n             let datevalue = await client.readProperty({\n                address: flow.get('ip')\n            }, {\n                instance: flow.get('deviceInstance'),\n                type: 8\n            }, bacnet.PropertyIdentifier.LOCAL_DATE);\n\n            let timevalue = await client.readProperty({\n                address: flow.get('ip')\n            }, {\n                instance: flow.get('deviceInstance'),\n                type: 8\n            }, bacnet.PropertyIdentifier.LOCAL_TIME);\n            let nightStartTime;\n            let nightEndTime;\n            let bacnetFullTime = bacnettimeConverter(datevalue.values[0].value, timevalue.values[0].value);\n            msg.payload = 'Are the night start/end times correct? \\n Press OK/NOT OK. \\n device time : ' + bacnetFullTime + '. \\n night start time: ' + nightStartTime + '. \\n night end time: ' + nightEndTime;\n            node.send([null, msg]);\n            break;\n        case (\"DONE\"):\n            \n            break;\n        case (\"OK\"):\n            step++;\n            node.warn(\"oops\");\n            flow.set('step',step);\n  \n            break;\n        case (\"NOK\"):\n            step++;\n            flow.set('step',step);\n            break;\n        case (\"SKIP\"):\n            step++;\n            flow.set('step',step);\n            break;\n    }\n\n\n\n function bacnettimeConverter(bacnetDate, bacnetTime) \n {\n    let date = \"\";\n    let time = \"\";\n    for (let i = 4; i < 15; i++) {\n        date += bacnetDate.toString()[i];\n    }\n    for (let i = 16; i < 24; i++) {\n\n        time += bacnetTime.toString()[i];\n\n    }\n    var bacnetFullTime = date + ' ' + time;\n    return bacnetFullTime;\n }\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
            {
                "var": "bacnet",
                "module": "@bacnet-js/client"
            }
        ],
        "x": 540,
        "y": 300,
        "wires": [
