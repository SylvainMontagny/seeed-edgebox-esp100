        "id": "75a95b66c42487f0",
        "type": "function",
        "z": "8b7d06cf1eb39e35",
        "name": "Connectivity (4G/WiFi) (0)",
        "func": "if (msg.payload != false)\n{\nlet temp = flow.get(\"tests\");\ntemp.connectivity = true;\nflow.set(\"tests\", temp);\n}\nlet step = flow.get('step');\nstep++;\nflow.set('step',step);\nmsg.payload = \"START\";\nreturn msg;",
