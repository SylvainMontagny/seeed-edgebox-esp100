        "name": "robustness",
        "func": "let step = flow.get('step');\nif(step == 2)\n{\n    let client = new bacnet.default({\n        apduTimeout: 2000,\n        broadcastAddress: flow.get('ipBroadcast'),\n        port: flow.get('port'),\n        maxSegments: bacnet.MaxSegmentsAccepted.SEGMENTS_65\n    });\n\n\n    switch (msg.payload)   \n    {\n        case (\"START\"):\n\n            break;\n        case (\"DONE\"):\n            \n            break;\n        case (\"OK\"):\n            step++;\n            flow.set('step',step);\n            break;\n        case (\"NOK\"):\n            step++;\n            flow.set('step',step);\n            break;\n        case (\"SKIP\"):\n            step++;\n            flow.set('step',step);\n            break;\n    }\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
